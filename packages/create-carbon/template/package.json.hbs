---
path: package.json
---

{
	"name": "{{name}}",
	"version": "1.0.0",
	"description": "{{#if (eq runtime "forwarder")}}A Discord Gateway Forwarder built with Carbon{{else}}A Discord bot built with Carbon{{/if}}",
	"type": "module",
	{{#if (eq runtime "node")}}
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "{{packageManager}} run build && node --watch --env-file-if-exists=.env .",
		"start": "node --env-file-if-exists=.env ."
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}",
		"@hono/node-server": "{{get versions "@hono/node-server"}}"
	},
	"devDependencies": {
		"@types/node": "{{get versions "@types/node"}}",
		"typescript": "{{get versions "typescript"}}"
	}
	{{else if (eq runtime "bun")}}
	"main": "./src/index.ts",
	"scripts": {
		"dev": "bun run . --watch",
		"start": "bun run ."
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}"
	},
	"devDependencies": {
		"@types/bun": "{{get versions "@types/bun"}}",
		"typescript": "{{get versions "typescript"}}"
	}
	{{else if (eq runtime "cloudflare")}}
	"main": "./src/index.ts",
	"scripts": {
		"dev": "wrangler dev --port 3000",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"postinstall": "wrangler types",
		"wrangler": "wrangler"
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}"
	},
	"devDependencies": {
		"@types/node": "{{get versions "@types/node"}}",
		"typescript": "{{get versions "typescript"}}",
		"wrangler": "{{get versions "wrangler"}}"
	}
	{{else if (eq runtime "deno")}}
	"main": "./src/index.ts",
	"scripts": {
		"build": "deno task check",
		"dev": "deno task dev",
		"start": "deno task start"
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}"
	}
	{{else if (eq runtime "fetch")}}
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "{{packageManager}} run build && node --watch --env-file-if-exists=.env dist/local.js",
		"start": "node --env-file-if-exists=.env dist/local.js"
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}",
		"@hono/node-server": "{{get versions "@hono/node-server"}}"
	},
	"devDependencies": {
		"@types/node": "{{get versions "@types/node"}}",
		"typescript": "{{get versions "typescript"}}"
	}
	{{else if (eq runtime "next")}}
	"main": "./src/app/api/discord/[...slug]/route.ts",
	"scripts": {
		"build": "next build",
		"dev": "next dev --turbo",
		"start": "next start"
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}",
		"next": "{{get versions "next"}}",
		"react": "{{get versions "react"}}",
		"react-dom": "{{get versions "react-dom"}}"
	},
	"devDependencies": {
		"@types/node": "{{get versions "@types/node"}}",
		"@types/react": "{{get versions "@types/react"}}",
		"@types/react-dom": "{{get versions "@types/react-dom"}}",
		"typescript": "{{get versions "typescript"}}"
	}
	{{else}}
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"start": "node --env-file-if-exists=.env dist/index.js",
		"dev": "{{packageManager}} run build && node --watch --env-file-if-exists=.env dist/index.js"
	},
	"dependencies": {
		"@buape/carbon": "{{get versions "@buape/carbon"}}"
	},
	"devDependencies": {
		"typescript": "{{get versions "typescript"}}"
	},
	"keywords": [
		"discord",
		"bot",
		"carbon",
		{{#if (eq runtime "forwarder")}}
		"gateway",
		"forwarder"
		{{else}}
		"typescript"
		{{/if}}
	],
	"author": "",
	"license": "MIT"
	{{/if}}
}
