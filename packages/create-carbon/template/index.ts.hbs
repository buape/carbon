---
{{#if (eq runtime "next")}}
path: src/app/api/discord/[...slug]/route.ts
{{else}}
path: src/index.ts
{{/if}}
---

{{#if (eq runtime "node")}}
import "dotenv/config"
{{/if}}
import { Client } from "@buape/carbon"
{{#if plugins.linkedRoles}}
import { LinkedRoles, ApplicationRoleConnectionMetadataType } from "@buape/carbon/linked-roles"
{{/if}}
{{#if plugins.gateway}}
{{#if (eq runtime "cloudflare")}}
import { GatewayIntents } from "@buape/carbon/gateway"
import {
	CloudflareGatewayDurableObject,
	CloudflareGatewayPlugin
} from "@buape/carbon/cloudflare-gateway"
{{else}}
import { GatewayIntents, GatewayPlugin } from "@buape/carbon/gateway"
{{/if}}
{{/if}}
{{#if (eq runtime "node")}}
import { serve } from "@hono/node-server"
import { createHandler } from "@buape/carbon/adapters/fetch"
{{else if (eq runtime "bun")}}
import { createServer } from "@buape/carbon/adapters/bun"
{{else if (or (eq runtime "cloudflare") (eq runtime "next") (eq runtime "deno") (eq runtime "fetch"))}}
import { createHandler } from "@buape/carbon/adapters/fetch"
{{/if}}
{{#if (eq runtime "next")}}
import PingCommand from "~/commands/ping"
import ButtonCommand from "~/commands/button"
import ApplicationAuthorized from "~/events/authorized"
{{#if plugins.gateway}}
import MessageCreate from "~/events/messageCreate"
{{/if}}
{{else if (eq runtime "deno")}}
import PingCommand from "./commands/ping.ts"
import ButtonCommand from "./commands/button.ts"
import ApplicationAuthorized from "./events/authorized.ts"
{{#if plugins.gateway}}
import MessageCreate from "./events/messageCreate.ts"
{{/if}}
{{else}}
import PingCommand from "./commands/ping.js"
import ButtonCommand from "./commands/button.js"
import ApplicationAuthorized from "./events/authorized.js"
{{#if plugins.gateway}}
import MessageCreate from "./events/messageCreate.js"
{{/if}}
{{/if}}

{{#if plugins.linkedRoles}}
const linkedRoles = new LinkedRoles({
	metadata: [
		{
			key: "is_staff",
			name: "Verified Staff",
			description: "Whether the user is a verified staff member",
			type: ApplicationRoleConnectionMetadataType.BooleanEqual
		},
	],
	metadataCheckers: {
		is_staff: async (userId) => {
			const isAllowed = ["439223656200273932"]
			if (isAllowed.includes(userId)) return true
			return false
		}
	}
})
{{/if}}

{{#if plugins.gateway}}
const gatewayIntents = GatewayIntents.Guilds | GatewayIntents.GuildMessages | GatewayIntents.MessageContent
{{#if (eq runtime "cloudflare")}}
const gateway = new CloudflareGatewayPlugin({
	intents: gatewayIntents
})
{{else}}
const gateway = new GatewayPlugin({
	intents: gatewayIntents
})
{{/if}}
{{/if}}

export const client = new Client(
	{
		baseUrl: {{#if (eq runtime "deno")}}Deno.env.get("BASE_URL"){{else}}process.env.BASE_URL{{/if}},
		deploySecret: {{#if (eq runtime "deno")}}Deno.env.get("DEPLOY_SECRET"){{else}}process.env.DEPLOY_SECRET{{/if}},
		clientId: {{#if (eq runtime "deno")}}Deno.env.get("DISCORD_CLIENT_ID"){{else}}process.env.DISCORD_CLIENT_ID{{/if}},
		{{#if plugins.linkedRoles}}
		clientSecret: {{#if (eq runtime "deno")}}Deno.env.get("DISCORD_CLIENT_SECRET"){{else}}process.env.DISCORD_CLIENT_SECRET{{/if}},
		{{/if}}
		publicKey: {{#if (eq runtime "deno")}}Deno.env.get("DISCORD_PUBLIC_KEY"){{else}}process.env.DISCORD_PUBLIC_KEY{{/if}},
		token: {{#if (eq runtime "deno")}}Deno.env.get("DISCORD_BOT_TOKEN"){{else}}process.env.DISCORD_BOT_TOKEN{{/if}},
		devGuilds: {{#if (eq runtime "deno")}}Deno.env.get("DISCORD_DEV_GUILDS")?.split(","){{else}}process.env.DISCORD_DEV_GUILDS?.split(","){{/if}}, // Optional: comma-separated list of dev guild IDs
	},
	{
		commands: [
			new PingCommand(),
			new ButtonCommand()
		], 
		listeners: [
			new ApplicationAuthorized(){{#if plugins.gateway}},
			new MessageCreate(){{/if}}
		],
	}{{#if (or plugins.linkedRoles plugins.gateway)}},
	[{{#if plugins.linkedRoles}}linkedRoles{{/if}}{{#if plugins.gateway}}{{#if plugins.linkedRoles}}, {{/if}}gateway{{/if}}]{{/if}}
)

{{#if (eq runtime "node")}}
const handler = createHandler(client)

serve({
	port: 3000,
	fetch: (request) => handler(request, {})
})
{{else if (eq runtime "bun")}}
createServer(client, { port: 3000 })
{{else if (eq runtime "cloudflare")}}
const handler = createHandler(client)

{{#if plugins.gateway}}
export { CloudflareGatewayDurableObject }
{{/if}}

export default {
	fetch(request: Request, env: Env, ctx: ExecutionContext) {
		return handler(request, { waitUntil: ctx.waitUntil.bind(ctx), env })
	}
} satisfies ExportedHandler<Env>
{{else if (eq runtime "next")}}
const handler = createHandler(client)
export const GET = (req: Request) => handler(req, {})
export const POST = (req: Request) => handler(req, {})
{{else if (eq runtime "deno")}}
const handler = createHandler(client)
Deno.serve((request) => handler(request, {}))
{{else if (eq runtime "fetch")}}
const handler = createHandler(client)
export const fetchHandler = (request: Request) => handler(request, {})
export default {
	fetch: fetchHandler
}
{{/if}}

{{#if (eq runtime "deno")}}
{{else}}
declare global {
	namespace NodeJS {
		interface ProcessEnv {
			BASE_URL: string;
			DEPLOY_SECRET: string;
			DISCORD_CLIENT_ID: string;
			{{#if plugins.linkedRoles}}
			DISCORD_CLIENT_SECRET: string;
			{{/if}}
			DISCORD_PUBLIC_KEY: string;
			DISCORD_BOT_TOKEN: string;
		}
	}
}
{{/if}}
