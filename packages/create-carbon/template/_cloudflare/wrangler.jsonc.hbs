---
{{#if (eq runtime "cloudflare")}}
path: wrangler.jsonc
{{/if}}
---

{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "{{name}}",
	"main": "src/index.ts",
	"compatibility_date": "2025-12-17",
	"observability": {
		"enabled": true
	},
	"compatibility_flags": [
		"nodejs_compat",
		"nodejs_compat_populate_process_env"
	]{{#if plugins.gateway}},
	"durable_objects": {
		"bindings": [
			{
				"name": "CARBON_GATEWAY",
				"class_name": "CloudflareGatewayDurableObject"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["CloudflareGatewayDurableObject"]
		}
	]{{/if}}
}
