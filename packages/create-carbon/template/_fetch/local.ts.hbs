---
{{#if (eq runtime "fetch")}}
path: src/local.ts
{{/if}}
---

{{#if (eq runtime "fetch")}}
import "dotenv/config"
import { serve } from "@hono/node-server"
import { createHandler } from "@buape/carbon/adapters/fetch"
import { client } from "./index.js"

const handler = createHandler(client)

serve({
	port: 3000,
	fetch: (request) => handler(request, {})
})
{{/if}}
