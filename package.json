{
	"name": "monorepo",
	"description": "Carbon monorepo",
	"private": true,
	"repository": "github:buape/carbon",
	"type": "module",
	"scripts": {
		"build": "turbo run build --filter !website",
		"changeset": "changeset add",
		"ci": "pnpm build --filter !website",
		"cf": "pnpm build --filter @buape/carbon... && turbo run dev --filter demo-cloudo",
		"cli": "cd packages/create-carbon && pnpm cli",
		"dev": "turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-socketo --filter !demo-pointo --filter !website",
		"dev:socketo": "turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-pointo --filter !demo-rocko --filter !website",
		"dev:forwarder": "turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-rocko --filter !website",
		"lint": "biome check . --write",
		"preinstall": "npx only-allow pnpm",
		"publish": "changeset version && pnpm run build && changeset publish --dry-run",
		"publish:snapshot": "changeset version --snapshot beta && pnpm run build && changeset publish --tag beta --no-git-tag ",
		"start": "turbo run start --filter !demo-cloudo",
		"test": "vitest",
		"web": "pnpm run web:dev",
		"web:dev": "pnpm --filter website run dev",
		"web:deploy": "pnpm --filter website run build && pnpm --filter website run deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@changesets/cli": "2.30.0",
		"@types/bun": "1.3.11",
		"@types/node": "25.6.0",
		"lefthook": "2.1.5",
		"turbo": "2.9.14",
		"typedoc": "0.28.18",
		"typedoc-plugin-mdn-links": "5.1.1",
		"typescript": "6.0.2",
		"vitest": "4.1.4"
	},
	"packageManager": "pnpm@10.24.0",
	"engines": {
		"node": ">=24"
	},
	"pnpm": {
		"overrides": {
			"lru-cache": "11.2.7"
		},
		"patchedDependencies": {
			"@tomehq/core@0.8.0": "patches/@tomehq__core@0.8.0.patch"
		}
	},
	"dependencies": {
		"@changesets/get-github-info": "^0.8.0",
		"@changesets/types": "^6.1.0"
	}
}
