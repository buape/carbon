{
	"name": "monorepo",
	"description": "Carbon monorepo",
	"private": true,
	"repository": "github:buape/carbon",
	"type": "module",
	"scripts": {
		"build": "turbo run build --filter !website",
		"changeset": "changeset add",
		"ci": "pnpm build --filter !website",
		"cf": "pnpm build --filter @buape/carbon... && turbo run dev --filter demo-cloudo",
		"cli": "cd packages/create-carbon && pnpm cli",
		"dev": "env-cmd -- turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-socketo --filter !demo-pointo --filter !website",
		"dev:socketo": "env-cmd -- turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-pointo --filter !demo-rocko --filter !website",
		"dev:forwarder": "env-cmd -- turbo run dev --env-mode loose --filter !demo-cloudo --filter !demo-rocko --filter !website",
		"lint": "biome check . --write",
		"preinstall": "npx only-allow pnpm",
		"publish": "changeset version && pnpm run build && changeset publish",
		"publish:snapshot": "changeset version --snapshot beta && pnpm run build && changeset publish --tag beta --no-git-tag ",
		"start": "turbo run start --filter !demo-cloudo",
		"test": "vitest",
		"web": "pnpm run web:dev",
		"web:dev": "pnpm --filter website run dev",
		"web:build": "pnpm --filter website run build",
		"web:deploy": "pnpm --filter website run deploy"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.10",
		"@changesets/changelog-git": "0.2.1",
		"@changesets/cli": "2.30.0",
		"@net-tech-/env-cmd": "1.0.3",
		"lefthook": "2.1.4",
		"tsc-watch": "7.2.0",
		"turbo": "2.9.3",
		"type-fest": "5.5.0",
		"typedoc": "0.28.18",
		"typedoc-plugin-frontmatter": "1.3.1",
		"typedoc-plugin-markdown": "4.11.0",
		"typedoc-plugin-mdn-links": "5.1.1",
		"typescript": "6.0.2",
		"vitest": "4.1.2"
	},
	"packageManager": "pnpm@10.24.0",
	"engines": {
		"node": ">=24"
	},
	"pnpm": {
		"overrides": {
			"lru-cache": "11.2.7"
		},
		"patchedDependencies": {
			"@tomehq/theme@0.7.0": "patches/@tomehq__theme@0.7.0.patch",
			"@tomehq/core": "patches/@tomehq__core.patch"
		}
	}
}
